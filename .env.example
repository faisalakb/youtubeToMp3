# ----------------------------------------------------------------------------
# mp3bat environment.
# Copy to `.env.local` and fill in. With NONE of these set, the app still runs:
# the converter works unlimited and auth/billing show a "not configured" state.
# Set the Supabase block to enable accounts + the soft cap; add the Stripe block
# to enable Pro upgrades.
# ----------------------------------------------------------------------------

# Public site URL (used for canonical/OG URLs, sitemap, auth + Stripe returns).
# Local dev: http://localhost:3000. PRODUCTION: set to https://mp3bat.com
# (if unset in prod, the app falls back to https://mp3bat.com automatically).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Affiliate link shown to visitors who need URL→MP3 (mp3bat doesn't do that).
# Replace with your real Wondershare UniConverter affiliate/referral URL.
NEXT_PUBLIC_UNICONVERTER_AFFILIATE_URL=

# Google Search Console verification token (the content="..." value from GSC's
# "HTML tag" method). Leave blank until you create the GSC property.
GOOGLE_SITE_VERIFICATION=

# Cookieless analytics (Plausible). Set to your verified domain, e.g. mp3bat.com,
# to load the privacy-first analytics script. Leave blank to load nothing.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# --- Supabase (enables accounts, magic-link auth, soft usage cap) ------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the browser. Used by the Stripe webhook to flip
# Pro status. (No NEXT_PUBLIC_ prefix on purpose.)
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (enables Pro subscriptions) --------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# The recurring price ID for the ~$5/mo Pro plan (price_...)
STRIPE_PRICE_ID=
